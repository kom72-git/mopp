{
  "name": "mopp-devcontainer",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "workspaceFolder": "/home/node/moop",
  "forwardPorts": [4173, 4000],
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "portsAttributes": {
    "4173": {
      "label": "MOPP Vite (frontend)",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "4000": {
      "label": "MOPP API",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "postCreateCommand": "npm install && npm --prefix api install",
  "postStartCommand": "bash ${containerWorkspaceFolder}/.devcontainer/start-services.sh",
  "postAttachCommand": "bash ${containerWorkspaceFolder}/.devcontainer/start-services.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on",
        "remote.restoreForwardedPorts": false
      },
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  }
}
